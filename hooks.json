{
  "trekker-hooks": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "python ${ANTIGRAVITY_PLUGIN_ROOT}/hooks/session-start.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python ${ANTIGRAVITY_PLUGIN_ROOT}/hooks/task-completed.py",
        "timeout": 10
      }
    ]
  }
}
